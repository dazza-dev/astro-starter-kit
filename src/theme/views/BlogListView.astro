---
import Layout from "../layouts/Layout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/I18nUtils";
import { buildUrl } from "../../lib/url";
import type { Post } from "../../types/blog";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("blog.title")}>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="mb-2 text-2xl font-bold text-gray-900">{t("blog.title")}</h1>
    <p class="mb-8 text-gray-500">{t("blog.subtitle")}</p>

    <div class="grid gap-6">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>

    {posts.length === 0 && <p class="text-gray-400">{t("blog.empty")}</p>}

    <div class="mt-8">
      <a href={buildUrl(lang)} class="text-blue-600 hover:underline">
        &larr; {t("nav.home")}
      </a>
    </div>
  </main>
</Layout>
