        >
      </div>

      <h1 class="mb-1 text-5xl font-bold">Starter Kit</h1>
    </div>

    <!-- Latest Posts -->
    {
      posts.length > 0 && (
        <section>
          <h2 class="mb-6 text-xl font-semibold text-gray-800">{t("blog.latestPosts")}</h2>
          <div class="grid gap-6">
            {posts.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
          <div class="mt-8 text-center">
            <a href={buildUrl(lang, "blog")} class="text-blue-600 hover:underline">
              {t("blog.viewAll")} &rarr;
            </a>
          </div>
        </section>
      )
    }

    {posts.length === 0 && <p class="text-center text-gray-400">{t("blog.empty")}</p>}
  </main>
</Layout>
