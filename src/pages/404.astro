---
let lang = "es";
try {
  const { defaultLang } = await import("../locales/Locales");
  const { getLangFromUrl } = await import("../i18n/I18nUtils");
  lang = getLangFromUrl(Astro.url) ?? defaultLang;
} catch {
  /* fallback to hardcoded default if imports fail */
}

const texts = {
  es: { title: "Pagina no encontrada", message: "La pagina que buscas no existe.", goHome: "Ir al inicio" },
  en: { title: "Page not found", message: "The page you are looking for does not exist.", goHome: "Go to home" },
};
const t = texts[lang as keyof typeof texts] ?? texts.es;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>404 | {t.title}</title>
    <meta name="description" content={t.message} />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f9fafb;
        font-family: system-ui, sans-serif;
        color: #1f2937;
      }
      .container {
        text-align: center;
        padding: 1.5rem;
      }
      h1 {
        font-size: 6rem;
        font-weight: 700;
        color: #6366f1;
        margin: 0 0 1rem;
      }
      p {
        font-size: 1.25rem;
        color: #6b7280;
        margin: 0 0 2rem;
      }
      a {
        display: inline-block;
        padding: 0.75rem 2rem;
        background: #6366f1;
        color: #fff;
        font-weight: 500;
        border-radius: 0.5rem;
        text-decoration: none;
      }
      @media (prefers-reduced-motion: no-preference) {
        a {
          transition: background 0.2s;
        }
      }
      a:hover {
        background: #4f46e5;
      }
    </style>
  </head>
  <body>
    <main class="container">
      <h1>404</h1>
      <p>{t.message}</p>
      <a href={`/${lang}/`}>{t.goHome}</a>
    </main>
  </body>
</html>
